{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bitloops hooks codex post-tool-use",
            "statusMessage": "Processing tool response...",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bitloops hooks codex pre-tool-use",
            "statusMessage": "Preparing tool call...",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bitloops hooks codex session-start",
            "statusMessage": "Initializing session...",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bitloops hooks codex stop",
            "statusMessage": "Wrapping up turn...",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bitloops hooks codex user-prompt-submit",
            "statusMessage": "Submitting prompt...",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ]
  }
}
